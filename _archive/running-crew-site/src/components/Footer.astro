---
import { site, nav } from "../data/site.js";
---
<footer class="ft">
  <div class="wrap ft-inner">
    <div class="ft-brand">
      <div class="ft-name">{site.crewNameEn}</div>
      <p class="ft-tag">{site.tagline}</p>
      <div class="ft-social">
        <a href={site.links.instagram} target="_blank" rel="noopener" class="ft-btn">Instagram</a>
        <a href={site.links.openchat} target="_blank" rel="noopener" class="ft-btn">오픈채팅</a>
        {site.links.strava && <a href={site.links.strava} target="_blank" rel="noopener" class="ft-btn">Strava</a>}
      </div>
    </div>
    <nav class="ft-nav" aria-label="푸터 메뉴">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>
  </div>
  <div class="wrap ft-bottom">
    <span>© {site.founded} {site.crewName}. 함께 달립니다.</span>
    <span class="ft-note">실시간 소통은 오픈채팅 · 인스타그램에서</span>
  </div>
</footer>

<style>
  .ft{background:var(--ink);color:#e7e9ec;margin-top:40px}
  .ft-inner{display:flex;justify-content:space-between;gap:30px;padding:48px 20px 24px;flex-wrap:wrap}
  .ft-name{font-size:20px;font-weight:900;color:#fff}
  .ft-tag{color:#9aa1ab;margin-top:6px}
  .ft-social{display:flex;gap:10px;margin-top:16px}
  .ft-btn{font-size:13px;font-weight:700;padding:8px 16px;border:1px solid #333842;border-radius:999px;color:#e7e9ec}
  .ft-btn:hover{background:var(--volt);color:var(--ink);border-color:var(--volt)}
  .ft-nav{display:grid;grid-template-columns:1fr 1fr;gap:8px 28px;align-content:start}
  .ft-nav a{color:#c4c9d0;font-size:14px}
  .ft-nav a:hover{color:var(--volt)}
  .ft-bottom{display:flex;justify-content:space-between;gap:14px;padding:18px 20px 40px;
    border-top:1px solid #23272e;font-size:12.5px;color:#7d848d;flex-wrap:wrap}
  @media(max-width:860px){.ft-inner{flex-direction:column}}
</style>
