---
import { site, nav } from "../data/site.js";
const path = Astro.url.pathname;
---
<header class="hd">
  <div class="wrap hd-inner">
    <a href="/" class="brand">
      <span class="brand-mark">▶</span>
      <span class="brand-txt">{site.crewNameEn}</span>
    </a>

    <nav class="hd-nav" aria-label="주요 메뉴">
      {nav.map((n) => (
        <a href={n.href} class={`hd-link${path === n.href ? " is-active" : ""}`}>{n.label}</a>
      ))}
    </nav>

    <a href="/join" class="btn btn-primary hd-cta">가입하기</a>

    <button class="hd-burger" aria-label="메뉴 열기" id="burger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="hd-mobile" id="mobileNav" aria-label="모바일 메뉴">
    {nav.map((n) => (
      <a href={n.href} class={`hd-mlink${path === n.href ? " is-active" : ""}`}>{n.label}</a>
    ))}
    <a href="/join" class="btn btn-primary" style="margin-top:8px">가입하기</a>
  </nav>
</header>

<style>
  .hd{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.9);backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line)}
  .hd-inner{display:flex;align-items:center;gap:18px;height:64px}
  .brand{display:flex;align-items:center;gap:9px;font-weight:900;letter-spacing:-.02em}
  .brand-mark{display:inline-grid;place-items:center;width:28px;height:28px;background:var(--ink);
    color:var(--volt);border-radius:8px;font-size:13px}
  .brand-txt{font-size:17px}
  .hd-nav{display:flex;gap:6px;margin-left:auto}
  .hd-link{font-size:15px;font-weight:600;color:#333;padding:8px 12px;border-radius:10px}
  .hd-link:hover{background:var(--soft)}
  .hd-link.is-active{color:var(--ink);font-weight:800;background:var(--soft)}
  .hd-cta{padding:9px 18px;font-size:14px}
  .hd-burger{display:none;flex-direction:column;gap:5px;background:none;border:0;cursor:pointer;padding:8px;margin-left:auto}
  .hd-burger span{width:24px;height:2.5px;background:var(--ink);border-radius:2px;transition:.2s}
  .hd-mobile{display:none;flex-direction:column;gap:2px;padding:12px 20px 20px;border-bottom:1px solid var(--line);background:#fff}
  .hd-mobile.open{display:flex}
  .hd-mlink{padding:12px 10px;font-weight:600;border-radius:10px}
  .hd-mlink.is-active{background:var(--soft);font-weight:800}
  @media(max-width:860px){
    .hd-nav,.hd-cta{display:none}
    .hd-burger{display:flex}
  }
</style>

<script>
  const b = document.getElementById("burger");
  const m = document.getElementById("mobileNav");
  b?.addEventListener("click", () => m?.classList.toggle("open"));
</script>
