---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site.js";
const r = site.regularRun;
---
<BaseLayout>
  <!-- ===== 히어로 ===== -->
  <section class="hero">
    <div class="wrap hero-inner">
      <span class="eyebrow">{site.region} · SINCE {site.founded}</span>
      <h1 class="hero-h1">
        오늘도, <span class="hi">{site.heroWord}</span> 달립니다.
      </h1>
      <p class="hero-tag">{site.tagline}</p>
      <div class="hero-cta">
        <a href="/join" class="btn btn-primary">이번 주 함께 달리기 →</a>
        <a href="/about" class="btn btn-ghost" style="border-color:#33383f;color:#fff">크루 소개</a>
      </div>
      <div class="hero-stats">
        <div><b>{r.day}</b><span>정기런</span></div>
        <div><b>{r.distance}</b><span>기본 거리</span></div>
        <div><b>No Drop</b><span>아무도 안 남겨요</span></div>
      </div>
    </div>
  </section>

  <!-- ===== 다음 정기런 (최우선 블록) ===== -->
  <section class="section nextrun-wrap">
    <div class="wrap">
      <div class="nextrun">
        <div class="nr-left">
          <span class="chip chip-volt">다음 정기런</span>
          <h2 class="nr-day">{r.day} · {r.time}</h2>
          <ul class="nr-meta">
            <li>📍 <b class="ph">{r.place}</b></li>
            <li>🏃 {r.distance} · {r.pace}</li>
            <li>💚 {r.note}</li>
          </ul>
        </div>
        <div class="nr-right">
          <p class="nr-help">처음이신가요? 부담 없이 오세요.<br/>초보 페이스로 함께 뜁니다.</p>
          <a href="/join" class="btn btn-dark">신청하기 →</a>
          <a href={site.links.openchat} target="_blank" rel="noopener" class="nr-chat">또는 오픈채팅으로 문의</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 크루 소개 요약 ===== -->
  <section class="section section-alt">
    <div class="wrap grid grid-3">
      <div class="card">
        <div class="feat-ico">👟</div>
        <h3>초보 환영</h3>
        <p class="lead" style="font-size:15px">{r.pace}. 처음 뛰는 사람 기준으로 페이스를 맞춥니다.</p>
      </div>
      <div class="card">
        <div class="feat-ico">🗓️</div>
        <h3>고정 리듬</h3>
        <p class="lead" style="font-size:15px">{r.day} {r.time}, 같은 자리에서. 습관이 되도록.</p>
      </div>
      <div class="card">
        <div class="feat-ico">🤝</div>
        <h3>연결이 상품</h3>
        <p class="lead" style="font-size:15px">달리기 후 커피 한 잔. 사람을 만나러 오는 크루.</p>
      </div>
    </div>
  </section>

  <!-- ===== 최신 갤러리(콘텐츠 신선도) ===== -->
  <section class="section">
    <div class="wrap">
      <span class="eyebrow">GALLERY</span>
      <h2 class="title">최근의 우리</h2>
      <p class="lead">매주의 기록이 쌓여 크루의 문화가 됩니다.</p>
      <div class="grid grid-3 mt-m">
        {[1,2,3].map((i)=>(
          <div class="gcard">
            <div class="gcard-img">사진 {i}</div>
            <div class="gcard-cap"><span class="ph">2026.○○.○○</span> 정기런</div>
          </div>
        ))}
      </div>
      <div class="center mt-m"><a href="/gallery" class="btn btn-ghost">갤러리 더보기</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero{background:var(--ink);color:#fff;overflow:hidden;position:relative}
  .hero::after{content:"";position:absolute;right:-120px;top:-120px;width:420px;height:420px;
    background:radial-gradient(circle,rgba(212,255,46,.18),transparent 70%);pointer-events:none}
  .hero-inner{padding:88px 20px 96px;position:relative}
  .hero .eyebrow{color:var(--volt)}
  .hero-h1{font-size:clamp(38px,7vw,72px);font-weight:900;margin:14px 0 10px;letter-spacing:-.03em}
  .hero-h1 .hi{color:var(--volt)}
  .hero-tag{font-size:clamp(17px,2.4vw,22px);color:#c4c9d0;max-width:520px}
  .hero-cta{display:flex;gap:12px;margin-top:30px;flex-wrap:wrap}
  .hero-stats{display:flex;gap:36px;margin-top:52px;flex-wrap:wrap}
  .hero-stats div{display:flex;flex-direction:column}
  .hero-stats b{font-size:24px;font-weight:900;color:var(--volt)}
  .hero-stats span{font-size:13px;color:#8b929b}

  .nextrun-wrap{padding-top:0;margin-top:-44px}
  .nextrun{background:var(--paper);border:1px solid var(--line);border-radius:22px;
    box-shadow:0 18px 40px rgba(13,15,18,.12);padding:32px;display:flex;justify-content:space-between;
    gap:30px;flex-wrap:wrap;position:relative;z-index:2}
  .nr-day{font-size:clamp(24px,4vw,34px);font-weight:900;margin:12px 0 14px}
  .nr-meta{list-style:none;display:flex;flex-direction:column;gap:8px;font-size:16px}
  .nr-right{display:flex;flex-direction:column;align-items:flex-start;gap:12px;
    border-left:1px solid var(--line);padding-left:30px;min-width:240px}
  .nr-help{color:var(--muted);font-size:15px}
  .nr-chat{font-size:13px;color:var(--muted);text-decoration:underline;text-underline-offset:3px}

  .feat-ico{font-size:30px;margin-bottom:6px}
  .card h3{font-size:19px;margin-bottom:6px}

  .gcard{border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:#fff}
  .gcard-img{aspect-ratio:4/3;display:grid;place-items:center;color:#9aa1ab;font-weight:700;
    background:repeating-linear-gradient(135deg,#f0f2f5,#f0f2f5 12px,#e9ecf0 12px,#e9ecf0 24px)}
  .gcard-cap{padding:12px 14px;font-size:14px;font-weight:600}

  @media(max-width:860px){
    .nr-right{border-left:0;border-top:1px solid var(--line);padding-left:0;padding-top:20px;width:100%}
    .nextrun-wrap{margin-top:-30px}
  }
</style>
